{
  "name": "@rekl0w/sanal-pos",
  "version": "0.1.0",
  "description": "Node.js, Bun ve TypeScript ile kullanılabilen Türkiye odaklı sanal POS orkestrasyon kütüphanesi",
  "author": "Rekl0w",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    ".env.example",
    "CONTRIBUTING.md",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rekl0w/sanal-pos.git"
  },
  "homepage": "https://github.com/Rekl0w/sanal-pos#readme",
  "bugs": {
    "url": "https://github.com/Rekl0w/sanal-pos/issues"
  },
  "keywords": [
    "sanalpos",
    "sanal-pos",
    "virtual-pos",
    "payment",
    "node",
    "bun",
    "npm",
    "typescript",
    "turkey",
    "pos"
  ],
  "engines": {
    "node": ">=18.18.0",
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "tsx watch server.ts",
    "start": "tsx server.ts",
    "build": "tsup index.ts --format esm,cjs --clean --outDir dist && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "cross-env RUN_LIVE_TESTS=true vitest run tests/live.integration.test.ts",
    "typecheck": "tsc --noEmit",
    "check": "npm run test && npm run typecheck",
    "prepack": "npm run build && npm run check"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@hono/zod-validator": "^0.7.6",
    "fast-xml-parser": "^5.5.9",
    "hono": "^4.12.9",
    "zod": "^4.3.6"
  }
}
